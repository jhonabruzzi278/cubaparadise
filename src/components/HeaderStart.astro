---
export interface Props {
    page: string;
    image?: string;
    subtitle?: string;
}
const { page, image = '/img/Cuba.webp', subtitle = 'Descubre la magia de Cuba con nosotros' } = Astro.props;
---

<section class="page-header">
    <div class="header-background">
        <img src={image} alt={page} loading="eager" decoding="async" />
        <div class="overlay"></div>
    </div>
    
    <div class="header-content">
        <div class="container">
            <div class="content-wrapper">
                <!-- Modern Breadcrumb -->
                <nav class="breadcrumb-modern" aria-label="breadcrumb">
                    <a href="/" class="breadcrumb-home">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                            <polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                        <span>Inicio</span>
                    </a>
                    <span class="breadcrumb-divider">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"/>
                        </svg>
                    </span>
                    <span class="breadcrumb-current">{page}</span>
                </nav>
                
                <h1 class="page-title">{page}</h1>
                <p class="page-subtitle">{subtitle}</p>
            </div>
        </div>
    </div>
</section>

<style>
    .page-header {
        position: relative;
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .header-background {
        position: absolute;
        inset: 0;
        z-index: 0;
    }

    .header-background img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transform: scale(1.1);
        animation: zoomIn 20s ease-out forwards;
    }

    @keyframes zoomIn {
        to {
            transform: scale(1);
        }
    }

    .overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(15, 23, 42, 0.9) 0%,
            rgba(15, 23, 42, 0.7) 50%,
            rgba(15, 23, 42, 0.5) 100%
        );
    }

    .header-content {
        position: relative;
        z-index: 1;
        width: 100%;
        padding: 6rem 0 4rem;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .content-wrapper {
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }

    /* Modern Breadcrumb */
    .breadcrumb-modern {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 2rem;
        padding: 0.625rem 1.25rem;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border-radius: 50px;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .breadcrumb-home {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .breadcrumb-home:hover {
        color: #7AB730;
    }

    .breadcrumb-home svg {
        transition: transform 0.3s ease;
    }

    .breadcrumb-home:hover svg {
        transform: scale(1.1);
    }

    .breadcrumb-divider {
        display: flex;
        align-items: center;
        color: rgba(255, 255, 255, 0.4);
    }

    .breadcrumb-divider svg {
        width: 14px;
        height: 14px;
    }

    .breadcrumb-current {
        color: white;
        font-size: 0.875rem;
        font-weight: 600;
        max-width: 300px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Título */
    .page-title {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        color: white;
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
        line-height: 1.1;
        text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        animation: slideUp 0.8s ease-out 0.2s both;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-subtitle {
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: rgba(255, 255, 255, 0.85);
        font-weight: 400;
        line-height: 1.6;
        animation: slideUp 0.8s ease-out 0.4s both;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .page-header {
            min-height: 50vh;
        }

        .header-content {
            padding: 5rem 0 3rem;
        }

        .breadcrumb-modern {
            padding: 0.5rem 1rem;
            gap: 0.5rem;
        }

        .breadcrumb-home span {
            display: none;
        }

        .breadcrumb-current {
            max-width: 200px;
            font-size: 0.8125rem;
        }
    }

    @media (max-width: 480px) {
        .page-header {
            min-height: 45vh;
        }

        .header-content {
            padding: 4rem 0 2.5rem;
        }

        .breadcrumb-current {
            max-width: 150px;
        }
    }
</style>
