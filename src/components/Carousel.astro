<style>
    /* HERO CAROUSEL - MINIMALISTA Y ELEGANTE */
    .hero-carousel {
        position: relative;
        height: 100vh;
        min-height: 600px;
        max-height: 900px;
        overflow: hidden;
        background: #0a0a0a;
    }

    .carousel-container {
        position: relative;
        width: 100%;
        height: 100%;
    }

    /* Slides */
    .slides-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
    }

    .slide {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        visibility: hidden;
        transition: opacity 1s ease, visibility 1s ease;
        z-index: 1;
    }

    .slide.active {
        opacity: 1;
        visibility: visible;
        z-index: 2;
    }

    /* Background */
    .slide-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .slide-background img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transform: scale(1.1);
        transition: transform 8s ease;
    }

    .slide.active .slide-background img {
        transform: scale(1);
    }

    .slide-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to right,
            rgba(10, 10, 10, 0.85) 0%,
            rgba(10, 10, 10, 0.4) 50%,
            rgba(10, 10, 10, 0.2) 100%
        );
    }

    /* Content */
    .slide-content {
        position: relative;
        z-index: 3;
        height: 100%;
        display: flex;
        align-items: center;
        padding: 0 5%;
        max-width: 1400px;
        margin: 0 auto;
    }

    .content-wrapper {
        max-width: 600px;
        padding-top: 80px;
    }

    /* Tag */
    .slide-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        font-weight: 600;
        color: #7AB730;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 1.5rem;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.6s ease 0.2s;
    }

    .slide.active .slide-tag {
        opacity: 1;
        transform: translateY(0);
    }

    .tag-dot {
        width: 8px;
        height: 8px;
        background: #7AB730;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    /* Title - Minimalista */
    .slide-title {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 700;
        color: #ffffff;
        line-height: 1.1;
        margin-bottom: 1.25rem;
        letter-spacing: -0.02em;
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s ease 0.3s;
    }

    .slide.active .slide-title {
        opacity: 1;
        transform: translateY(0);
    }

    /* Description */
    .slide-description {
        font-size: clamp(1.0625rem, 2vw, 1.25rem);
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.6;
        margin-bottom: 2.5rem;
        max-width: 480px;
        font-weight: 400;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.8s ease 0.4s;
    }

    .slide.active .slide-description {
        opacity: 1;
        transform: translateY(0);
    }

    /* Actions */
    .slide-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.8s ease 0.5s;
    }

    .slide.active .slide-actions {
        opacity: 1;
        transform: translateY(0);
    }

    /* CTA Buttons */
    .cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem 2rem;
        font-size: 0.9375rem;
        font-weight: 600;
        text-decoration: none;
        border-radius: 8px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        letter-spacing: -0.01em;
    }

    .cta-btn.primary {
        background: #ffffff;
        color: #0a0a0a;
        box-shadow: 0 4px 20px rgba(255, 255, 255, 0.2);
    }

    .cta-btn.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(255, 255, 255, 0.3);
        background: #f5f5f5;
    }

    .cta-btn.secondary {
        background: transparent;
        color: #ffffff;
        border: 1.5px solid rgba(255, 255, 255, 0.3);
    }

    .cta-btn.secondary:hover {
        border-color: #ffffff;
        background: rgba(255, 255, 255, 0.1);
    }

    .cta-btn .material-symbols-outlined {
        font-size: 1.25rem;
        transition: transform 0.3s ease;
    }

    .cta-btn:hover .material-symbols-outlined {
        transform: translateX(4px);
    }

    /* Navigation */
    .carousel-navigation {
        position: absolute;
        bottom: 50%;
        transform: translateY(50%);
        left: 0;
        right: 0;
        display: flex;
        justify-content: space-between;
        padding: 0 2rem;
        z-index: 10;
        pointer-events: none;
    }

    .nav-btn {
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        color: white;
        cursor: pointer;
        pointer-events: auto;
        transition: all 0.3s ease;
    }

    .nav-btn:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: scale(1.1);
    }

    .nav-btn .material-symbols-outlined {
        font-size: 1.5rem;
    }

    /* Progress Bar */
    .carousel-progress {
        position: absolute;
        bottom: 80px;
        left: 5%;
        right: 5%;
        height: 2px;
        background: rgba(255, 255, 255, 0.2);
        z-index: 10;
        max-width: 200px;
    }

    .progress-bar {
        height: 100%;
        background: #7AB730;
        width: 0%;
        transition: width 0.1s linear;
    }

    /* Indicators */
    .carousel-indicators {
        position: absolute;
        bottom: 40px;
        left: 5%;
        display: flex;
        gap: 0.75rem;
        z-index: 10;
    }

    .indicator {
        width: 40px;
        height: 3px;
        background: rgba(255, 255, 255, 0.3);
        border: none;
        border-radius: 2px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .indicator.active {
        background: #7AB730;
        width: 60px;
    }

    .indicator:hover {
        background: rgba(255, 255, 255, 0.6);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .hero-carousel {
            min-height: 100svh;
            max-height: none;
        }

        .slide-content {
            padding: 0 1.5rem;
            align-items: flex-end;
            padding-bottom: 120px;
        }

        .content-wrapper {
            padding-top: 0;
            max-width: 100%;
        }

        .slide-overlay {
            background: linear-gradient(
                to top,
                rgba(10, 10, 10, 0.95) 0%,
                rgba(10, 10, 10, 0.6) 50%,
                rgba(10, 10, 10, 0.3) 100%
            );
        }

        .carousel-navigation {
            display: none;
        }

        .carousel-progress {
            left: 1.5rem;
            right: 1.5rem;
            bottom: 100px;
        }

        .carousel-indicators {
            left: 1.5rem;
            bottom: 60px;
        }

        .slide-actions {
            flex-direction: column;
        }

        .cta-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
        const slides = document.querySelectorAll('.slide');
        const indicators = document.querySelectorAll('.indicator');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const progressBar = document.getElementById('progressBar');
        
        let currentSlide = 0;
        let autoplayInterval = null;
        let progressInterval = null;
        const autoplayDelay = 6000;

        function showSlide(index) {
            slides.forEach((slide, i) => {
                slide.classList.toggle('active', i === index);
            });
            indicators.forEach((indicator, i) => {
                indicator.classList.toggle('active', i === index);
            });
            currentSlide = index;
            resetProgress();
        }

        function nextSlide() {
            const next = (currentSlide + 1) % slides.length;
            showSlide(next);
        }

        function prevSlide() {
            const prev = (currentSlide - 1 + slides.length) % slides.length;
            showSlide(prev);
        }

        function resetProgress() {
            if (progressBar) {
                progressBar.style.transition = 'none';
                progressBar.style.width = '0%';
                setTimeout(() => {
                    progressBar.style.transition = `width ${autoplayDelay}ms linear`;
                    progressBar.style.width = '100%';
                }, 50);
            }
        }

        function startAutoplay() {
            stopAutoplay();
            resetProgress();
            autoplayInterval = setInterval(nextSlide, autoplayDelay);
        }

        function stopAutoplay() {
            if (autoplayInterval) {
                clearInterval(autoplayInterval);
                autoplayInterval = null;
            }
        }

        // Event listeners
        nextBtn?.addEventListener('click', () => {
            nextSlide();
            startAutoplay();
        });

        prevBtn?.addEventListener('click', () => {
            prevSlide();
            startAutoplay();
        });

        indicators.forEach((indicator, index) => {
            indicator.addEventListener('click', () => {
                showSlide(index);
                startAutoplay();
            });
        });

        // Pause on hover
        const carousel = document.querySelector('.hero-carousel');
        carousel?.addEventListener('mouseenter', stopAutoplay);
        carousel?.addEventListener('mouseleave', startAutoplay);

        // Touch support
        let touchStartX = 0;
        carousel?.addEventListener('touchstart', (e) => {
            touchStartX = e.touches[0].clientX;
            stopAutoplay();
        }, { passive: true });

        carousel?.addEventListener('touchend', (e) => {
            const touchEndX = e.changedTouches[0].clientX;
            const diff = touchStartX - touchEndX;
            if (Math.abs(diff) > 50) {
                if (diff > 0) nextSlide();
                else prevSlide();
            }
            startAutoplay();
        }, { passive: true });

        // Initialize
        startAutoplay();
    });
</script>
